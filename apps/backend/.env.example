PORT=4000

# Etherscan V2 — covers ETH, BSC, Polygon, Base, Arbitrum + 60 more chains
# Get yours at https://etherscan.io/apis
ETHERSCAN_API_KEY=

# Moralis — multi-chain token + wallet data
# Get yours at https://moralis.io
MORALIS_API_KEY=

# GoPlus Security — honeypot + contract safety
# Get yours at https://gopluslabs.io
GOPLUS_APP_KEY=

# Helius — Solana token data
# Get yours at https://helius.dev
HELIUS_API_KEY=

# CoinGecko — price + market data
# Get yours at https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Ollama — local AI for human-readable summaries (must be running: ollama serve)
# TracSentinel works without Ollama — summaries will just be omitted.
#
# Use any model you have installed. Recommended:
#   qwen2.5:7b     — best quality, 4.7GB  (default)
#   qwen2.5:3b     — faster, lighter, 2GB
#   llama3.2:3b    — good alternative, 2GB
#   mistral:7b     — solid all-rounder, 4.1GB
#
# To see your installed models: ollama list
# To pull a model:              ollama pull <model-name>
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# DexScreener — no key needed, public API

# TAP Protocol — uses the public Trac API (tap.trac.network) by default. No setup needed.
# Optional: set this to use your own local tap-reader node as fallback/primary.
# Setup: git clone https://github.com/Trac-Systems/tap-reader && cd tap-reader && npm i && npm start
# Requires ~150GB SSD, 8GB RAM, Node 20+.
# TAP_READER_URL=http://localhost:5099

# Trac SC-Bridge — P2P network (optional — leave empty to disable P2P)
# Lets this node share scan results with other TracSentinel nodes on the Trac Network.
# Get your bridge credentials from: https://tracsystems.io
SC_BRIDGE_URL=ws://127.0.0.1:49222
SC_BRIDGE_TOKEN=

# Telegram Bot (optional — leave empty to disable)
# Create a bot via @BotFather on Telegram, copy the token here
TELEGRAM_BOT_TOKEN=
# Public URL where TracSentinel is accessible (used for shareable links in bot messages)
SENTINEL_URL=http://localhost:4000
